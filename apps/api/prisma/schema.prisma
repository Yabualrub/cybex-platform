generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tickets            Ticket[]
  users              User[]
  agentConversations AgentConversation[]
  agentSettings      AgentSettings?
  auditLogs          AuditLog[]
  tenantServices     TenantService[]
}

model User {
  id                     String              @id @default(cuid())
  email                  String              @unique
  password               String?
  fullName               String?
  role                   Role                @default(OWNER)
  status                 UserStatus           @default(ACTIVE)

  inviteToken            String?
  inviteTokenExpiresAt   DateTime?
  resetToken             String?
  resetTokenExpiresAt    DateTime?

  tenantId               String
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  ticketsCreated         Ticket[]            @relation("TicketCreatedBy")
  ticketMessages         TicketMessage[]     @relation("TicketMessageAuthor")
  tenant                 Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentConversations     AgentConversation[] @relation("AgentConversationOwner")
  agentMessages          AgentMessage[]      @relation("AgentMessageAuthor")
  auditLogs              AuditLog[]

  @@index([tenantId])
  @@index([status])
}

model Ticket {
  id          String          @id @default(cuid())
  tenantId    String
  title       String
  description String
  status      TicketStatus    @default(OPEN)
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy   User?           @relation("TicketCreatedBy", fields: [createdById], references: [id])
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]

  @@index([tenantId])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String?
  body      String
  createdAt DateTime @default(now())

  author    User?    @relation("TicketMessageAuthor", fields: [authorId], references: [id])
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model TenantService {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  enabled   Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("tenant_services")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  userId     String?
  action     String
  entityType String?
  entityId   String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model AgentSettings {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  displayName  String   @default("Cybex AI Agent")
  language     String   @default("en")
  tone         String   @default("professional")
  businessInfo Json?
  hours        Json?
  rules        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("agent_settings")
}

model AgentConversation {
  id                 String         @id @default(cuid())
  tenantId           String
  channel            AgentChannel   @default(WEB)
  subject            String?
  external           String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  languagePreference String?
  ownerUserId        String

  ownerUser          User           @relation("AgentConversationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages           AgentMessage[]

  @@index([tenantId])
  @@index([tenantId, ownerUserId])
  @@map("agent_conversations")
}

model AgentMessage {
  id              String            @id @default(cuid())
  conversationId  String
  role            String
  content         String
  createdByUserId String?
  createdAt       DateTime          @default(now())

  conversation    AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdByUser   User?             @relation("AgentMessageAuthor", fields: [createdByUserId], references: [id])

  @@index([conversationId])
  @@index([createdByUserId])
  @@map("agent_messages")
}

enum Role {
  OWNER
  ADMIN
  TECH
  USER
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum AgentChannel {
  WEB
  EMAIL
  WHATSAPP
  SMS
}
